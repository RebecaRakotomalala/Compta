@model dadaApp.Models.IssueDashboardViewModel

@{
    ViewData["Title"] = "Issue";
    Layout = null;

    var clientNames = ViewBag.AllClientNames as List<string> ?? new List<string>();
    var selectedClient = ViewBag.ClientFilter as string;

    var grandDebit = Model?.Semaines != null ? Model.Semaines.Sum(s => s.TotalDebit) : 0m;
    var grandCredit = Model?.Semaines != null ? Model.Semaines.Sum(s => s.TotalCredit) : 0m;
    var nbEcritures = Model?.Semaines != null ? Model.Semaines.Sum(s => s.Clients.Sum(c => c.Ecritures.Count)) : 0;
}

@await Html.PartialAsync("_Navbar")

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
<link rel="stylesheet" href="~/css/issue.css" />

<div class="issue-container issue-container--wide">
    <div class="issue-header">
        <div class="issue-title-block">
            <div class="issue-icon">
                <i class="bi bi-calendar-week"></i>
            </div>
            <div>
                <h1 class="issue-title">Issue par semaine</h1>
                <p class="issue-subtitle">
                    Écritures <strong>non lettrées</strong>, réparties selon la <strong>date d’échéance</strong>.
                    Cinq fenêtres : il y a 2 semaines, semaine dernière, cette semaine, semaine prochaine, dans 2 semaines (lun–dim).
                </p>
            </div>
        </div>
    </div>

    <form asp-action="Index" method="get" class="issue-filters issue-filters--compact">
        <div class="issue-filter-group issue-filter-group--grow">
            <label class="form-label">Client</label>
            <div class="custom-select-wrapper" id="issueClientSelectWrapper">
                <input type="text"
                       id="issueClientSearchInput"
                       class="custom-select-search"
                       placeholder="Rechercher ou sélectionner un client..."
                       autocomplete="off"
                       value="@selectedClient" />
                <i class="bi bi-chevron-down custom-select-arrow"></i>

                <div class="custom-select-dropdown" id="issueClientDropdown">
                    <div class="custom-select-count" id="issueClientCount">
                        @clientNames.Count clients disponibles
                    </div>
                    <div class="custom-select-option" data-value="">
                        <strong>Tous les clients</strong>
                    </div>
                    @foreach (var client in clientNames)
                    {
                        <div class="custom-select-option" data-value="@client">
                            @client
                        </div>
                    }
                    <div class="custom-select-no-results" id="issueNoResults" style="display: none;">
                        Aucun client trouvé
                    </div>
                </div>
            </div>

            <input type="hidden" name="client" id="issueClientHiddenInput" value="@selectedClient" />
        </div>
        <div class="issue-filters-actions">
            <a asp-action="Index" class="issue-btn issue-btn-secondary">
                <i class="bi bi-x-circle"></i> Réinitialiser
            </a>
            <button type="submit" class="issue-btn issue-btn-primary">
                <i class="bi bi-search"></i> Filtrer
            </button>
        </div>
    </form>

    @if (Model?.Semaines != null && Model.Semaines.Any())
    {
        <div class="issue-weeks-board-wrapper">
            <div class="issue-weeks-board">
                @{
                    var idx = 0;
                }
                @foreach (var sem in Model.Semaines)
                {
                    idx++;
                    var modifier = sem.Id switch
                    {
                        "m2" or "m1" => "issue-week-col--past",
                        "s0" => "issue-week-col--current",
                        _ => "issue-week-col--future"
                    };
                    var anyLine = sem.Clients.Sum(c => c.Ecritures.Count) > 0;

                    <section class="issue-week-col @modifier" aria-labelledby="week-title-@sem.Id">
                        <header class="issue-week-col-head">
                            <span class="issue-week-badge">@(sem.Id == "s0" ? "→ " : "")@idx / 5</span>
                            <h2 id="week-title-@sem.Id" class="issue-week-title">@sem.Titre</h2>
                            <p class="issue-week-period"><i class="bi bi-calendar3"></i> @sem.PeriodeLibelle</p>
                            <div class="issue-week-totals">
                                <div class="issue-week-total-row">
                                    <span>Débit</span>
                                    <strong>@sem.TotalDebit.ToString("N2")</strong>
                                </div>
                                <div class="issue-week-total-row">
                                    <span>Crédit</span>
                                    <strong>@sem.TotalCredit.ToString("N2")</strong>
                                </div>
                            </div>
                        </header>

                        <div class="issue-week-col-body">
                            @if (!anyLine)
                            {
                                <div class="issue-week-empty">
                                    <i class="bi bi-check2-circle"></i>
                                    <span>Aucune échéance cette semaine</span>
                                </div>
                            }
                            else
                            {
                                @foreach (var bloc in sem.Clients)
                                {
                                    <details class="issue-client-bloc"@Html.Raw(sem.Clients.Count <= 3 ? " open" : "")>
                                        <summary class="issue-client-bloc-sum">
                                            <span class="issue-client-bloc-name" title="@bloc.NomClient">
                                                @bloc.NomClient
                                            </span>
                                            <span class="issue-client-bloc-meta">
                                                <span class="issue-client-code">@bloc.CodeClient</span>
                                                <span class="issue-client-subtot">
                                                    @bloc.TotalDebit.ToString("N2") / @bloc.TotalCredit.ToString("N2")
                                                </span>
                                            </span>
                                        </summary>
                                        <div class="issue-mini-table-wrap">
                                            <table class="issue-mini-table">
                                                <thead>
                                                    <tr>
                                                        <th>Échéance</th>
                                                        <th>Pièce</th>
                                                        <th class="num">Débit</th>
                                                        <th class="num">Crédit</th>
                                                    </tr>
                                                </thead>
                                                <tbody>
                                                    @foreach (var ec in bloc.Ecritures)
                                                    {
                                                        <tr>
                                                            <td>
                                                                @if (ec.DateEcheance.HasValue)
                                                                {
                                                                    <span>@ec.DateEcheance.Value.ToString("dd/MM/yy")</span>
                                                                }
                                                                else { <span class="text-muted">-</span>; }
                                                            </td>
                                                            <td class="issue-mini-piece" title="@ec.Libelle">@(ec.NumeroPiece ?? "-")</td>
                                                            <td class="num">@ec.Debit.ToString("N2")</td>
                                                            <td class="num">@ec.Credit.ToString("N2")</td>
                                                        </tr>
                                                    }
                                                </tbody>
                                            </table>
                                        </div>
                                    </details>
                                }
                            }
                        </div>
                    </section>
                }
            </div>
        </div>

        @if (nbEcritures > 0)
        {
            <div class="issue-grand-total">
                <span><i class="bi bi-calculator"></i> Synthèse sur les 5 semaines (@nbEcritures ligne(s))</span>
                <span class="issue-grand-total-nums">
                    Débit <strong>@grandDebit.ToString("N2")</strong>
                    · Crédit <strong>@grandCredit.ToString("N2")</strong>
                </span>
            </div>
        }
    }
    else
    {
        <div class="issue-results-card">
            <div class="issue-empty">
                <i class="bi bi-info-circle"></i>
                <p>Aucune donnée à afficher.</p>
            </div>
        </div>
    }
</div>

<script>
    document.addEventListener('DOMContentLoaded', function () {
        const wrapper = document.getElementById('issueClientSelectWrapper');
        const searchInput = document.getElementById('issueClientSearchInput');
        const hiddenInput = document.getElementById('issueClientHiddenInput');
        const dropdown = document.getElementById('issueClientDropdown');
        const options = dropdown.querySelectorAll('.custom-select-option');
        const noResults = document.getElementById('issueNoResults');
        const countDisplay = document.getElementById('issueClientCount');

        let allOptions = Array.from(options);

        const currentValue = hiddenInput.value;
        if (currentValue) {
            allOptions.forEach(opt => {
                if (opt.dataset.value === currentValue) {
                    opt.classList.add('selected');
                }
            });
        }

        function openDropdown() {
            wrapper.classList.add('open');
            filterOptions('');
        }

        searchInput.addEventListener('focus', openDropdown);
        searchInput.addEventListener('click', openDropdown);

        searchInput.addEventListener('input', function () {
            const term = this.value.toLowerCase();
            filterOptions(term);
        });

        function filterOptions(term) {
            let visibleCount = 0;

            allOptions.forEach(option => {
                const text = option.textContent.toLowerCase();
                const value = (option.dataset.value || '').toLowerCase();

                if (!term || text.includes(term) || value.includes(term) || option.dataset.value === '') {
                    option.classList.remove('hidden');
                    visibleCount++;
                } else {
                    option.classList.add('hidden');
                }
            });

            if (visibleCount <= 1) {
                noResults.style.display = 'block';
            } else {
                noResults.style.display = 'none';
            }

            const actualCount = visibleCount - 1;
            if (term) {
                countDisplay.textContent = `${actualCount} client${actualCount > 1 ? 's' : ''} trouvé${actualCount > 1 ? 's' : ''}`;
            } else {
                countDisplay.textContent = `${actualCount} clients disponibles`;
            }
        }

        allOptions.forEach(option => {
            option.addEventListener('click', function () {
                const value = this.dataset.value;
                const text = this.textContent.trim();

                searchInput.value = value === '' ? '' : text;
                hiddenInput.value = value;

                allOptions.forEach(opt => opt.classList.remove('selected'));
                this.classList.add('selected');

                wrapper.classList.remove('open');
            });
        });

        document.addEventListener('click', function (e) {
            if (!wrapper.contains(e.target)) {
                wrapper.classList.remove('open');
            }
        });
    });
</script>
