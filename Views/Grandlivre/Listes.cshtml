async function appliquerProposition(ecritureIds) {
    // Fonction conservée pour compatibilité, sans boîtes de dialogue bloquantes
    await creerLettragePourEcritures(ecritureIds);
    location.reload();
}

function majSelectionPropositions() {
    const checkboxes = document.querySelectorAll('.proposition-checkbox:checked');
    const btn = document.getElementById('btnAppliquerSelection');
    if (btn) {
        btn.disabled = checkboxes.length === 0;
    }
}

async function appliquerPropositionsSelectionnees() {
    const checkboxes = document.querySelectorAll('.proposition-checkbox:checked');
    if (checkboxes.length === 0) return;
    
    const btn = document.getElementById('btnAppliquerSelection');
    if (btn) {
        btn.disabled = true;
        btn.innerHTML = '<i class="bi bi-arrow-repeat spin"></i> Application en cours...';
    }
    
    const toutesLesPromesses = [];
    const erreurs = [];
    const idsAppliques = [];
    
    for (const cb of checkboxes) {
        const ids = (cb.dataset.ecritures || '')
            .split(',')
            .map(x => parseInt(x, 10))
            .filter(x => !isNaN(x));
        
        if (ids.length > 0) {
            idsAppliques.push(...ids);
            toutesLesPromesses.push(
                creerLettragePourEcritures(ids)
                    .catch(error => {
                        erreurs.push({ ids, error: error.message });
                        return null;
                    })
            );
        }
    }
    
    try {
        const resultats = await Promise.all(toutesLesPromesses);
        const succes = resultats.filter(r => r !== null).length;
        const echecs = erreurs.length;
        
        console.log(`✅ ${succes} lettrage(s) créé(s) avec succès`);
        if (echecs > 0) {
            console.error(`❌ ${echecs} lettrage(s) ont échoué:`, erreurs);
        }
        
        // Créer un mapping : ID écriture -> Numéro lettrage
        const mappingEcritureLettrage = new Map();
        checkboxes.forEach((cb, index) => {
            const ids = (cb.dataset.ecritures || '')
                .split(',')
                .map(x => parseInt(x, 10))
                .filter(x => !isNaN(x));
            
            if (resultats[index] && resultats[index].numeroLettrage) {
                const numeroLettrage = resultats[index].numeroLettrage;
                ids.forEach(id => {
                    mappingEcritureLettrage.set(id, numeroLettrage);
                });
            }
        });
        
        console.log(`📋 Mapping créé: ${mappingEcritureLettrage.size} écritures mappées`);
        
        // Attendre un peu pour que la base de données soit à jour
        console.log('⏳ Attente de la sauvegarde en base de données...');
        await new Promise(resolve => setTimeout(resolve, 500));
        
        // Retirer visuellement les propositions appliquées de l'affichage
        console.log('🗑️ Retrait des propositions appliquées de l\'affichage...');
        checkboxes.forEach(cb => {
            const card = cb.closest('div[style*="background: white"]');
            if (card) {
                // Animation de disparition
                card.style.transition = 'opacity 0.3s, transform 0.3s';
                card.style.opacity = '0';
                card.style.transform = 'translateX(-20px)';
                setTimeout(() => {
                    card.style.display = 'none';
                }, 300);
            }
        });
        
        // Mettre à jour le tableau pour remplacer les checkboxes par les badges de lettrage
        console.log('🔄 Mise à jour du tableau...');
        mappingEcritureLettrage.forEach((numeroLettrage, ecritureId) => {
            const row = document.querySelector(`tr[data-ecriture-id="${ecritureId}"]`);
            if (row) {
                const lettrageCell = row.querySelector('.lettrage-cell');
                const checkbox = row.querySelector('.ecriture-checkbox');
                
                if (lettrageCell && checkbox) {
                    // Remplacer la checkbox par le badge de lettrage
                    lettrageCell.innerHTML = `<span class="lettrage-badge">${numeroLettrage}</span>`;
                    // Retirer la classe de highlight
                    row.classList.remove('proposition-highlight');
                }
            }
        });
        
        // Mettre à jour la sélection
        updateSelection();
        
        // Mettre à jour le compteur et le bouton
        majSelectionPropositions();
        
        // Re-vérifier les propositions depuis le serveur pour mettre à jour l'affichage
        // (cela va exclure automatiquement les propositions avec écritures lettrées)
        console.log('🔄 Re-vérification des propositions depuis le serveur...');
        await rechercherPropositions();
        
        console.log('✅ Mise à jour terminée');
    } catch (e) {
        console.error('Erreur lors de la création de certains lettrages', e);
        if (btn) {
            btn.disabled = false;
            btn.innerHTML = '<i class="bi bi-check-circle"></i> Appliquer les propositions sélectionnées';
        }
    }
}

function filtrerPropositionsLettre(idsEcrituresLettre) {
    // Retirer les propositions qui contiennent des écritures déjà lettrées
    const checkboxes = document.querySelectorAll('.proposition-checkbox');
    checkboxes.forEach(cb => {
        const ids = (cb.dataset.ecritures || '')
            .split(',')
            .map(x => parseInt(x, 10))
            .filter(x => !isNaN(x));
        
        // Si cette proposition contient une écriture qui vient d'être lettrée, la masquer
        const contientEcritureLettre = ids.some(id => idsEcrituresLettre.includes(id));
        if (contientEcritureLettre) {
            const card = cb.closest('div[style*="background: white"]');
            if (card) {
                card.style.display = 'none';
            }
        }
    });
    
    // Mettre à jour le compteur et le bouton
    majSelectionPropositions();
}

function selectionnerToutesPropositions() {
    console.log('🔍 [JS] Sélectionner tout appelé');
    const checkboxes = document.querySelectorAll('.proposition-checkbox');
    console.log(`🔍 [JS] ${checkboxes.length} checkboxes trouvées`);
    
    if (checkboxes.length === 0) {
        console.warn('🔍 [JS] Aucune checkbox trouvée');
        return;
    }
    
    const btnSelectAll = document.getElementById('btnSelectAllPropositions');
    const tousCoches = Array.from(checkboxes).every(cb => cb.checked);
    const nouvelleValeur = !tousCoches;
    
    console.log(`🔍 [JS] Tous cochés: ${tousCoches}, nouvelle valeur: ${nouvelleValeur}`);
    
    checkboxes.forEach((cb, index) => {
        cb.checked = nouvelleValeur;
        console.log(`🔍 [JS] Checkbox ${index + 1} mise à ${nouvelleValeur}`);
    });
    
    if (btnSelectAll) {
        btnSelectAll.innerHTML = nouvelleValeur 
            ? '<i class="bi bi-square"></i> Désélectionner tout'
            : '<i class="bi bi-check-square"></i> Sélectionner tout';
    }
    
    majSelectionPropositions();
    console.log('🔍 [JS] Sélection mise à jour');
}

async function creerLettragePourEcritures(ecritureIds) {
    try {
        const response = await fetch('@Url.Action("CreerLettrage", "Grandlivre")', {
            method: 'POST',
            headers: {
                'Content-Type': 'application/json',
            },
            body: JSON.stringify(ecritureIds)
        });
        
        if (!response.ok) {
            throw new Error(`HTTP error! status: ${response.status}`);
        }
        
        const result = await response.json();
        
        if (!result.success) {
            throw new Error(result.message || 'Erreur lors de la création du lettrage');
        }
        
        console.log('✅ Lettrage créé:', result.numeroLettrage);
        return result;
    } catch (error) {
        console.error('❌ Erreur lors de la création du lettrage:', error);
        throw error;
    }
}

