<script>
let selectedEcritures = [];

function updateSelection() {
    const checkboxes = document.querySelectorAll('.ecriture-checkbox:checked');
    selectedEcritures = Array.from(checkboxes).map(cb => ({
        id: parseInt(cb.value),
        client: cb.closest('tr').dataset.client,
        debit: parseFloat(cb.closest('tr').dataset.debit),
        credit: parseFloat(cb.closest('tr').dataset.credit)
    }));
    
    // Afficher/masquer la barre d'info
    const infoSection = document.getElementById('lettrageInfo');
    if (selectedEcritures.length > 0) {
        infoSection.classList.remove('hide');
        infoSection.style.display = 'block';
    } else {
        infoSection.classList.add('hide');
        setTimeout(() => {
            infoSection.style.display = 'none';
        }, 400);
        return;
    }
    
    const totalDebit = selectedEcritures.reduce((sum, e) => sum + e.debit, 0);
    const totalCredit = selectedEcritures.reduce((sum, e) => sum + e.credit, 0);
    const solde = totalDebit - totalCredit;
    
    document.getElementById('selectedCount').textContent = selectedEcritures.length;
    document.getElementById('selectedDebit').textContent = totalDebit.toFixed(2);
    document.getElementById('selectedCredit').textContent = totalCredit.toFixed(2);
    document.getElementById('selectedSolde').textContent = solde.toFixed(2);
    
    // Colorier le solde
    const soldeElement = document.getElementById('selectedSolde');
    if (Math.abs(solde) < 0.01) {
        soldeElement.style.color = 'green';
    } else {
        soldeElement.style.color = 'red';
    }
    
    // Vérifier les conditions
    const clients = [...new Set(selectedEcritures.map(e => e.client))];
    const canValidate = selectedEcritures.length >= 2 && 
                       clients.length === 1 && 
                       Math.abs(solde) < 0.01;
    
    document.getElementById('validerLettrage').disabled = !canValidate;
}

function resetSelection() {
    document.querySelectorAll('.ecriture-checkbox').forEach(cb => cb.checked = false);
    selectedEcritures = [];
    updateSelection();
}

document.getElementById('validerLettrage')?.addEventListener('click', async function() {
    if (selectedEcritures.length < 2) {
        alert('Sélectionnez au moins 2 écritures');
        return;
    }
    
    const btn = document.getElementById('validerLettrage');
    if (btn) {
        btn.disabled = true;
        btn.innerHTML = '<i class="bi bi-arrow-repeat spin"></i> Création...';
    }
    
    const ids = selectedEcritures.map(e => e.id);
    
    try {
        console.log('📝 [JS] Création de lettrage manuel pour', ids.length, 'écritures');
        const response = await fetch('@Url.Action("CreerLettrage", "Grandlivre")', {
            method: 'POST',
            headers: {
                'Content-Type': 'application/json',
            },
            body: JSON.stringify(ids)
        });
        
        if (!response.ok) {
            throw new Error(`HTTP error! status: ${response.status}`);
        }
        
        const result = await response.json();
        
        if (result.success) {
            console.log('✅ [JS] Lettrage créé:', result.numeroLettrage);
            
            // Attendre un peu pour que la base de données soit à jour
            await new Promise(resolve => setTimeout(resolve, 300));
            
            // Mettre à jour le tableau pour remplacer les checkboxes par les badges de lettrage
            const numeroLettrage = result.numeroLettrage || 'LM';
            ids.forEach(ecritureId => {
                const row = document.querySelector(`tr[data-ecriture-id="${ecritureId}"]`);
                if (row) {
                    const lettrageCell = row.querySelector('.lettrage-cell');
                    const checkbox = row.querySelector('.ecriture-checkbox');
                    
                    if (lettrageCell && checkbox) {
                        // Remplacer la checkbox par le badge de lettrage
                        lettrageCell.innerHTML = `<span class="lettrage-badge">${numeroLettrage}</span>`;
                        // Retirer la classe de highlight
                        row.classList.remove('proposition-highlight');
                    }
                }
            });
            
            // Réinitialiser la sélection
            resetSelection();
            
            // Re-vérifier les propositions depuis le serveur
            console.log('🔄 [JS] Re-vérification des propositions...');
            await rechercherPropositions();
            
            console.log('✅ [JS] Lettrage manuel créé avec succès');
        } else {
            alert('Erreur: ' + result.message);
            if (btn) {
                btn.disabled = false;
                btn.innerHTML = '<i class="bi bi-check-circle"></i> Valider le lettrage';
            }
        }
    } catch (error) {
        console.error('❌ [JS] Erreur:', error);
        alert('Erreur de communication avec le serveur: ' + error.message);
        if (btn) {
            btn.disabled = false;
            btn.innerHTML = '<i class="bi bi-check-circle"></i> Valider le lettrage';
        }
    }
});

// Tri des colonnes
document.addEventListener('DOMContentLoaded', function() {
    let currentSort = {
        column: null,
        direction: 'asc' // 'asc' ou 'desc'
    };

    function parseValue(text, sortType) {
        if (sortType === 'date' || sortType === 'echeance') {
            // Convertir dd/MM/yy en nombre pour comparaison
            const parts = text.trim().split('/');
            if (parts.length === 3) {
                const day = parseInt(parts[0], 10);
                const month = parseInt(parts[1], 10);
                const year = parseInt(parts[2], 10);
                return new Date(year + 2000, month - 1, day).getTime();
            }
            return 0;
        } else if (sortType === 'lettrage') {
            // Pour le lettrage, on trie par valeur de texte
            return text.trim();
        }
        return text.trim();
    }

    function sortTable(columnName) {
        const table = document.querySelector('table');
        const tbody = table.querySelector('tbody');
        const rows = Array.from(tbody.querySelectorAll('tr'));

        // Déterminer la direction de tri
        if (currentSort.column === columnName) {
            currentSort.direction = currentSort.direction === 'asc' ? 'desc' : 'asc';
        } else {
            currentSort.column = columnName;
            currentSort.direction = 'asc';
        }

        // Mettre à jour les flèches visuellement
        document.querySelectorAll('.sortable').forEach(th => {
            th.querySelectorAll('.sort-arrows span').forEach(arrow => {
                arrow.classList.remove('active');
            });
        });

        const activeHeader = document.querySelector(`.sortable[data-sort="${columnName}"]`);
        if (activeHeader) {
            if (currentSort.direction === 'asc') {
                activeHeader.querySelector('.arrow-up').classList.add('active');
            } else {
                activeHeader.querySelector('.arrow-down').classList.add('active');
            }
        }

        // Trier les lignes
        rows.sort((rowA, rowB) => {
            let valueA, valueB;

            if (columnName === 'date') {
                valueA = parseValue(rowA.querySelector('.date-cell').textContent, 'date');
                valueB = parseValue(rowB.querySelector('.date-cell').textContent, 'date');
            } else if (columnName === 'echeance') {
                valueA = parseValue(rowA.querySelector('.echeance-cell').textContent, 'echeance');
                valueB = parseValue(rowB.querySelector('.echeance-cell').textContent, 'echeance');
            } else if (columnName === 'lettrage') {
                valueA = parseValue(rowA.querySelector('.lettrage-cell').textContent, 'lettrage');
                valueB = parseValue(rowB.querySelector('.lettrage-cell').textContent, 'lettrage');
            }

            if (typeof valueA === 'string') {
                return currentSort.direction === 'asc' 
                    ? valueA.localeCompare(valueB, 'fr')
                    : valueB.localeCompare(valueA, 'fr');
            } else {
                return currentSort.direction === 'asc' 
                    ? valueA - valueB
                    : valueB - valueA;
            }
        });

        // Réappliquer les lignes triées
        rows.forEach(row => tbody.appendChild(row));
    }

    // Ajouter les écouteurs d'événements
    document.querySelectorAll('.sortable').forEach(th => {
        th.addEventListener('click', function() {
            const sortColumn = this.getAttribute('data-sort');
            sortTable(sortColumn);
        });
    });
});
</script>