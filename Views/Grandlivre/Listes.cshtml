@model List<dadaApp.Models.Ecriture>

@{
    ViewData["Title"] = "Grand Livre";
    Layout = null;
    
    // Configuration de pagination
    int pageSize = ViewBag.PageSize ?? 50;
    int currentPage = ViewBag.CurrentPage ?? 1;
    int totalItems = ViewBag.TotalItems ?? 0;
    int totalPages = (int)Math.Ceiling((double)totalItems / pageSize);
    
    var pagedEcritures = Model?.Skip((currentPage - 1) * pageSize).Take(pageSize).ToList() ?? new List<Ecriture>();
    
    // Statistiques avancées
    var totalDebit = Model?.Sum(e => e.Debit) ?? 0;
    var totalCredit = Model?.Sum(e => e.Credit) ?? 0;
    var solde = totalDebit - totalCredit;
    var distinctAccounts = Model?.Select(e => e.Compte?.NumeroCompte).Where(c => !string.IsNullOrEmpty(c)).Distinct().Count() ?? 0;
    
    // Données pour les filtres
    var clientNames = ViewBag.AllClientNames as List<string> ?? new List<string>();
    
    var lettres = Model?
        .Select(e => e.NumeroLettrage)
        .Where(l => !string.IsNullOrEmpty(l))
        .Distinct()
        .OrderBy(l => l)
        .ToList() ?? new List<string>();
    
    // Récupérer les paramètres de filtre
    var selectedClient = ViewBag.SelectedClient as string;
    var filterType = ViewBag.FilterType as string ?? "all";

    bool isClientFiltered = !string.IsNullOrWhiteSpace(selectedClient);

    string clientLabel = isClientFiltered
        ? selectedClient!
        : "Tous";

    int clientCount = isClientFiltered
        ? 1
        : clientNames.Count;

}

@await Html.PartialAsync("_Navbar")

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
<link rel="stylesheet" href="~/css/grandlivre.css" />
<link rel="stylesheet" href="~/css/lettrage-notif.css" />

<div class="container">
    <!-- Page Header -->
    <div class="page-header">
        <div class="header-content">
            <h1 class="page-title">
                <i class="bi bi-journal-bookmark-fill"></i>
                Grand Livre Client
            </h1>
            <p class="page-subtitle">
                Visualisation et analyse complète des écritures comptables – 
                @totalItems écritures | @distinctAccounts comptes distincts | 
                Solde: @solde.ToString("N2")
            </p>
        </div>
        <div class="header-actions">
            <a href="@Url.Action("Index", "Import")" class="action-btn secondary">
                <i class="bi bi-cloud-arrow-up"></i>
                Nouvel import
            </a>
            <button class="action-btn danger" onclick="window.print()">
                <i class="bi bi-printer"></i>
                Imprimer
            </button>
        </div>
    </div>

    <!-- Stats Dashboard -->
    <div class="stats-dashboard">
        <div class="stat-card">
            <div class="stat-icon warning">
                <i class="bi bi-people"></i>
            </div>
            <div class="stat-content">
                @if (isClientFiltered)
                {
                    <div class="stat-value stat-client-name">
                        @clientLabel
                    </div>
                    <div class="stat-label">
                        Client sélectionné
                    </div>
                }
                else
                {
                    <div class="stat-value">
                        @clientCount
                    </div>
                    <div class="stat-label">
                        Clients uniques
                    </div>
                }
            </div>
        </div>

        <div class="stat-card">
            <div class="stat-icon success">
                <i class="bi bi-calculator"></i>
            </div>
            <div class="stat-content">
                <div class="stat-value">@totalDebit.ToString("N2")</div>
                <div class="stat-label">Total Débit</div>
            </div>
        </div>
        
        <div class="stat-card">
            <div class="stat-icon danger">
                <i class="bi bi-calculator-fill"></i>
            </div>
            <div class="stat-content">
                <div class="stat-value">@totalCredit.ToString("N2")</div>
                <div class="stat-label">Total Crédit</div>
            </div>
        </div>

        <div class="stat-card">
            <div class="stat-icon @(solde >= 0 ? "success" : "danger")">
                <i class="bi @(solde >= 0 ? "bi-graph-up-arrow" : "bi-graph-down-arrow")"></i>
            </div>
            <div class="stat-content">
                @if (@solde < 0)
                {
                    <div class="stat-value" style="color: red;">@solde.ToString("N2")</div>
                }else {
                    <div class="stat-value">@solde.ToString("N2")</div>
                }
                <div class="stat-trend @(solde >= 0 ? "trend-up" : "trend-down")">
                    <i class="bi @(solde >= 0 ? "bi-arrow-up" : "bi-arrow-down")"></i>
                    @(solde >= 0 ? "Solde débiteur" : "Solde créditeur")
                </div>
            </div>
        </div>
    </div>

    <!-- Barre d'information lettrage -->
    <div class="lettrage-info-section" id="lettrageInfo" style="display: none;">
        <div class="alert alert-info">
            <div class="d-flex justify-content-between align-items-center">
                <div>
                    <i class="bi bi-check2-square"></i>
                    <strong>Lettrage en cours</strong>
                    <br>
                    <small>
                        <span id="selectedCount">0</span> écritures sélectionnées | 
                        Débit: <span id="selectedDebit">0.00</span> | 
                        Crédit: <span id="selectedCredit">0.00</span> | 
                        Solde: <span id="selectedSolde" class="fw-bold">0.00</span>
                    </small>
                </div>
                <div>
                    <button class="btn btn-success btn-sm" id="validerLettrage" disabled>
                        <i class="bi bi-check-circle"></i> Valider le lettrage
                    </button>
                    <button class="btn btn-secondary btn-sm" onclick="resetSelection()">
                        <i class="bi bi-x-circle"></i> Réinitialiser
                    </button>
                </div>
            </div>
        </div>
    </div>

    <!-- Filters Section -->
    <div class="filters-section">
        <div class="filters-header">
            <h3 class="filters-title">
                <i class="bi bi-funnel"></i>
                Filtres de recherche
            </h3>
        </div>
        
        <form id="filterForm" method="get" class="filter-form">
            <div class="filter-content">
                <!-- Filtre par nom client avec recherche dynamique -->
                <div class="filter-group">
                    <label class="filter-label">
                        <i class="bi bi-person"></i>
                        Nom du client
                    </label>
                    
                    <div class="custom-select-wrapper" id="clientSelectWrapper">
                        <input type="text"
                               id="clientSearchInput"
                               class="custom-select-search"
                               placeholder="Rechercher ou sélectionner un client..."
                               autocomplete="off"
                               value="@selectedClient" />
                        <i class="bi bi-chevron-down custom-select-arrow"></i>
                        
                        <div class="custom-select-dropdown" id="clientDropdown">
                            <div class="custom-select-count" id="clientCount">
                                @clientNames.Count clients disponibles
                            </div>
                            <div class="custom-select-option" data-value="">
                                <strong>Tous les clients</strong>
                            </div>
                            @foreach (var client in clientNames)
                            {
                                <div class="custom-select-option" data-value="@client">
                                    @client
                                </div>
                            }
                            <div class="custom-select-no-results" id="noResults" style="display: none;">
                                Aucun client trouvé
                            </div>
                        </div>
                    </div>
                    
                    <!-- Input caché pour soumettre la valeur -->
                    <input type="hidden" name="client" id="clientHiddenInput" value="@selectedClient" />
                </div>
                
                <!-- Filtre par lettrage -->
                <div class="filter-group">
                    <label class="filter-label">
                        <i class="bi bi-tag"></i>
                        Statut de lettrage
                    </label>
                    <div class="lettrage-buttons">
                        <button type="button" class="lettrage-btn @(filterType == "all" ? "active" : "")" 
                                onclick="setFilterType('all')">
                            Tous
                        </button>
                        <button type="button" class="lettrage-btn @(filterType == "non-lettre" ? "active" : "")" 
                                onclick="setFilterType('non-lettre')">
                            Non lettré
                        </button>
                        <button type="button" class="lettrage-btn @(filterType == "lettre" ? "active" : "")" 
                                onclick="setFilterType('lettre')">
                            Lettré
                        </button>
                    </div>
                    <input type="hidden" name="filterType" id="filterType" value="@filterType">
                </div>
            </div>
            
            <div class="filter-actions">
                <button type="button" class="action-btn secondary" onclick="resetFilters()">
                    <i class="bi bi-x-circle"></i>
                    Réinitialiser
                </button>
                <button type="submit" class="action-btn primary">
                    <i class="bi bi-filter"></i>
                    Appliquer les filtres
                </button>
            </div>
        </form>
    </div>

    <!-- Section Propositions de Lettrage -->
    <div class="propositions-section" style="margin: 20px 0; padding: 15px; background: #f8f9fa; border-radius: 8px; border: 1px solid #dee2e6;">
        <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 15px; gap: 10px; flex-wrap: wrap;">
            <h4 style="margin: 0; color: #495057;">
                <i class="bi bi-lightbulb"></i>
                Propositions de lettrage automatique
            </h4>
            <div style="display: flex; gap: 8px; align-items: center; flex-wrap: wrap;">
            <button class="btn btn-primary" id="btnRechercherPropositions" onclick="rechercherPropositions()">
                <i class="bi bi-search"></i>
                Rechercher les propositions
            </button>
                <button class="btn btn-secondary" id="btnSelectAllPropositions" onclick="selectionnerToutesPropositions()" style="display: none;">
                    <i class="bi bi-check-square"></i>
                    Sélectionner tout
                </button>
                <button class="btn btn-success" id="btnAppliquerSelection" onclick="appliquerPropositionsSelectionnees()" disabled>
                    <i class="bi bi-check-circle"></i>
                    Appliquer les propositions sélectionnées
                </button>
            </div>
        </div>
        
        <div id="propositionsContainer" style="display: none;">
            <div id="propositionsLoading" style="text-align: center; padding: 20px; display: none;">
                <i class="bi bi-arrow-repeat spin"></i> Recherche en cours...
            </div>
            <div id="propositionsList" style="display: none;"></div>
            <div id="propositionsEmpty" style="text-align: center; padding: 20px; color: #6c757d; display: none;">
                <i class="bi bi-info-circle"></i> Aucune proposition de lettrage trouvée
            </div>
        </div>
    </div>

    <!-- Table Section -->
    <div class="table-container">
        <div class="page-size-selector">
            <label>
                Afficher
                <input type="number"
                    min="1"
                    max="500"
                    value="@pageSize"
                    onchange="changePageSize(this.value)"
                    style="width: 80px; text-align:center;" />
                lignes
            </label>
        </div>
        <div class="table-wrapper">
            @if (pagedEcritures.Any())
            {
                <table class="table">
                    <thead>
                        <tr>
                            <th width="80" class="sortable" data-sort="date">
                                Date
                                <span class="sort-arrows">
                                    <span class="arrow-up">▲</span>
                                    <span class="arrow-down">▼</span>
                                </span>
                            </th>
                            <th width="100">Code Client</th>
                            <th width="150">Client/Four.</th>
                            <th width="80">Journal</th>
                            <th width="80">Pièce</th>
                            <th width="200">Libellé</th>
                            <th width="80" class="sortable" data-sort="echeance">
                                Échéance
                                <span class="sort-arrows">
                                    <span class="arrow-up">▲</span>
                                    <span class="arrow-down">▼</span>
                                </span>
                            </th>
                            <th width="90" class="text-right">Débit</th>
                            <th width="90" class="text-right">Crédit</th>
                            <th width="90" class="text-center sortable" data-sort="lettrage">
                                Lettrage
                                <span class="sort-arrows">
                                    <span class="arrow-up">▲</span>
                                    <span class="arrow-down">▼</span>
                                </span>
                            </th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var e in pagedEcritures)
                        {
                            <tr data-ecriture-id="@e.EcritureId" 
                                data-client="@e.Compte?.CodeClient" 
                                data-debit="@e.Debit" 
                                data-credit="@e.Credit">
                                
                                <!-- Date -->
                                <td class="date-cell">
                                    @e.DateComptable.ToString("dd/MM/yy")
                                </td>
                                
                                <!-- Code Client -->
                                <td class="code-cell">
                                    <span class="code-badge">@e.Compte?.CodeClient</span>
                                </td>
                                
                                <!-- Client/Fournisseur -->
                                <td class="client-cell">
                                    <div class="client-name" title="@e.Compte?.NomClient">
                                        @(string.IsNullOrEmpty(e.Compte?.NomClient) ? "-" : e.Compte.NomClient)
                                    </div>
                                </td>
                                
                                <!-- Journal -->
                                <td class="journal-cell">
                                    <span class="journal-code">@e.CodeJournal</span>
                                </td>
                                
                                <!-- Pièce -->
                                <td class="piece-cell">
                                    <code>@e.NumeroPiece</code>
                                </td>
                                
                                <!-- Libellé -->
                                <td class="libelle-cell">
                                    <div title="@e.Libelle">
                                        @e.Libelle
                                    </div>
                                </td>
                                
                                <!-- Échéance -->
                                <td class="echeance-cell">
                                    @if (e.DateEcheance.HasValue)
                                    {
                                        <span class="echeance-date @(e.DateEcheance.Value < DateTime.Now ? "overdue" : "")">
                                            @e.DateEcheance.Value.ToString("dd/MM/yy")
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="text-muted">-</span>
                                    }
                                </td>
                                
                                <!-- Débit -->
                                <td class="debit-cell text-right">
                                    @if (e.Debit > 0)
                                    {
                                        <span class="debit-amount">
                                            @e.Debit.ToString("N2")
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="text-muted">-</span>
                                    }
                                </td>
                                
                                <!-- Crédit -->
                                <td class="credit-cell text-right">
                                    @if (e.Credit > 0)
                                    {
                                        <span class="credit-amount">
                                            @e.Credit.ToString("N2")
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="text-muted">-</span>
                                    }
                                </td>
                                
                                <!-- Lettrage avec checkbox -->
                                <td class="lettrage-cell text-center">
                                    @if (!string.IsNullOrWhiteSpace(e.NumeroLettrage))
                                    {
                                        <span class="lettrage-badge">
                                            @e.NumeroLettrage
                                        </span>
                                    }
                                    else
                                    {
                                        <input type="checkbox" 
                                               class="ecriture-checkbox" 
                                               value="@e.EcritureId"
                                               onchange="updateSelection()">
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                    <tfoot>
                        <tr class="totals-row">
                            <td colspan="6" class="text-left">
                                <strong>Totaux page (@pagedEcritures.Count écritures)</strong>
                            </td>
                            <td class="text-center">
                                <small>@pagedEcritures.Count(e => e.DateEcheance.HasValue) éch.</small>
                            </td>
                            <td class="text-right debit-total">
                                <strong>@pagedEcritures.Sum(e => e.Debit).ToString("N2")</strong>
                            </td>
                            <td class="text-right credit-total">
                                <strong>@pagedEcritures.Sum(e => e.Credit).ToString("N2")</strong>
                            </td>
                            <td class="text-center">
                                <small>@pagedEcritures.Count(e => !string.IsNullOrWhiteSpace(e.NumeroLettrage)) lett.</small>
                            </td>
                        </tr>
                        @if (Model != null && Model.Any())
                        {
                            <tr class="grand-totals-row">
                                <td colspan="6" class="text-left">
                                    <strong>Totaux généraux (@Model.Count écritures)</strong>
                                </td>
                                <td class="text-center">
                                    <small>@Model.Count(e => e.DateEcheance.HasValue) éch.</small>
                                </td>
                                <td class="text-right debit-total">
                                    <strong>@Model.Sum(e => e.Debit).ToString("N2")</strong>
                                </td>
                                <td class="text-right credit-total">
                                    <strong>@Model.Sum(e => e.Credit).ToString("N2")</strong>
                                </td>
                                <td class="text-center">
                                    <small>@Model.Count(e => !string.IsNullOrWhiteSpace(e.NumeroLettrage)) lett.</small>
                                </td>
                            </tr>
                        }
                    </tfoot>
                </table>
            }
            else
            {
                <div class="empty-state">
                    <div class="empty-icon">
                        <i class="bi bi-table"></i>
                    </div>
                    <h3 class="empty-title">Aucune écriture trouvée</h3>
                    <p class="empty-description">
                        Aucune donnée n'est disponible pour le moment. 
                        Importez vos données CSV ou ajustez vos critères de recherche.
                    </p>
                    <a href="@Url.Action("Index", "Import")" class="action-btn primary">
                        <i class="bi bi-cloud-arrow-up"></i>
                        Importer des données
                    </a>
                </div>
            }
        </div>
    </div>

    <!-- Pagination -->
    @if (totalPages > 1)
    {
        <div class="pagination-container">
            <div class="pagination-info">
                Affichage de <strong>@(((currentPage - 1) * pageSize) + 1)</strong> à 
                <strong>@Math.Min(currentPage * pageSize, totalItems)</strong> sur 
                <strong>@totalItems</strong> écritures
            </div>
            
            <nav>
                <ul class="pagination">
                    <li class="page-item @(currentPage == 1 ? "disabled" : "")">
                        <a class="page-link" href="?page=1&client=@selectedClient&filterType=@filterType">
                            <i class="bi bi-chevron-double-left"></i>
                        </a>
                    </li>
                    <li class="page-item @(currentPage == 1 ? "disabled" : "")">
                        <a class="page-link" href="?page=@(currentPage - 1)&client=@selectedClient&filterType=@filterType">
                            <i class="bi bi-chevron-left"></i>
                        </a>
                    </li>
                    
                    @for (int i = 1; i <= totalPages; i++)
                    {
                        if (i == 1 || i == totalPages || (i >= currentPage - 2 && i <= currentPage + 2))
                        {
                            <li class="page-item @(i == currentPage ? "active" : "")">
                                <a class="page-link" href="?page=@i&client=@selectedClient&filterType=@filterType&pageSize=@pageSize">@i</a>
                            </li>
                        }
                        else if (i == currentPage - 3 || i == currentPage + 3)
                        {
                            <li class="page-item disabled">
                                <span class="page-link">...</span>
                            </li>
                        }
                    }
                    
                    <li class="page-item @(currentPage == totalPages ? "disabled" : "")">
                        <a class="page-link" href="?page=@(currentPage + 1)&client=@selectedClient&filterType=@filterType">
                            <i class="bi bi-chevron-right"></i>
                        </a>
                    </li>
                    <li class="page-item @(currentPage == totalPages ? "disabled" : "")">
                        <a class="page-link" href="?page=@totalPages&client=@selectedClient&filterType=@filterType">
                            <i class="bi bi-chevron-double-right"></i>
                        </a>
                    </li>
                </ul>
            </nav>
        </div>
    }
</div>

<!-- Scripts pour le select customisé avec recherche -->
<script>
    document.addEventListener('DOMContentLoaded', function() {
        const wrapper = document.getElementById('clientSelectWrapper');
        const searchInput = document.getElementById('clientSearchInput');
        const hiddenInput = document.getElementById('clientHiddenInput');
        const dropdown = document.getElementById('clientDropdown');
        const options = dropdown.querySelectorAll('.custom-select-option');
        const noResults = document.getElementById('noResults');
        const countDisplay = document.getElementById('clientCount');
        
        let allOptions = Array.from(options);
        
        // Marquer l'option sélectionnée au chargement
        const currentValue = hiddenInput.value;
        if (currentValue) {
            allOptions.forEach(opt => {
                if (opt.dataset.value === currentValue) {
                    opt.classList.add('selected');
                }
            });
        }
        
        // Ouvrir/fermer le dropdown
        searchInput.addEventListener('focus', function() {
            wrapper.classList.add('open');
            filterOptions('');
        });
        
        searchInput.addEventListener('click', function() {
            wrapper.classList.add('open');
        });
        
        // Recherche dynamique
        searchInput.addEventListener('input', function() {
            const searchTerm = this.value.toLowerCase();
            filterOptions(searchTerm);
        });
        
        // Fonction de filtrage
        function filterOptions(searchTerm) {
            let visibleCount = 0;
            
            allOptions.forEach(option => {
                const text = option.textContent.toLowerCase();
                const value = option.dataset.value.toLowerCase();
                
                if (text.includes(searchTerm) || value.includes(searchTerm) || option.dataset.value === '') {
                    option.classList.remove('hidden');
                    visibleCount++;
                } else {
                    option.classList.add('hidden');
                }
            });
            
            // Afficher/masquer le message "Aucun résultat"
            if (visibleCount === 0 || (visibleCount === 1 && allOptions[0].dataset.value === '')) {
                noResults.style.display = 'block';
            } else {
                noResults.style.display = 'none';
            }
            
            // Mettre à jour le compteur
            const actualCount = visibleCount - 1; // -1 pour exclure "Tous les clients"
            if (searchTerm) {
                countDisplay.textContent = `${actualCount} client${actualCount > 1 ? 's' : ''} trouvé${actualCount > 1 ? 's' : ''}`;
            } else {
                countDisplay.textContent = `${actualCount} clients disponibles`;
            }
        }
        
        // Sélection d'une option
        allOptions.forEach(option => {
            option.addEventListener('click', function() {
                const value = this.dataset.value;
                const text = this.textContent.trim();
                
                // Mettre à jour les inputs
                searchInput.value = value === '' ? '' : text;
                hiddenInput.value = value;
                
                // Mettre à jour les classes selected
                allOptions.forEach(opt => opt.classList.remove('selected'));
                this.classList.add('selected');
                
                // Fermer le dropdown
                wrapper.classList.remove('open');
            });
        });
        
        // Fermer le dropdown en cliquant ailleurs
        document.addEventListener('click', function(e) {
            if (!wrapper.contains(e.target)) {
                wrapper.classList.remove('open');
            }
        });
        
        // Navigation au clavier
        searchInput.addEventListener('keydown', function(e) {
            const visibleOptions = allOptions.filter(opt => !opt.classList.contains('hidden'));
            const currentSelected = visibleOptions.findIndex(opt => opt.classList.contains('selected'));
            
            if (e.key === 'ArrowDown') {
                e.preventDefault();
                wrapper.classList.add('open');
                if (currentSelected < visibleOptions.length - 1) {
                    allOptions.forEach(opt => opt.classList.remove('selected'));
                    visibleOptions[currentSelected + 1].classList.add('selected');
                    visibleOptions[currentSelected + 1].scrollIntoView({ block: 'nearest' });
                }
            } else if (e.key === 'ArrowUp') {
                e.preventDefault();
                if (currentSelected > 0) {
                    allOptions.forEach(opt => opt.classList.remove('selected'));
                    visibleOptions[currentSelected - 1].classList.add('selected');
                    visibleOptions[currentSelected - 1].scrollIntoView({ block: 'nearest' });
                }
            } else if (e.key === 'Enter') {
                e.preventDefault();
                const selected = visibleOptions.find(opt => opt.classList.contains('selected'));
                if (selected) {
                    selected.click();
                }
            } else if (e.key === 'Escape') {
                wrapper.classList.remove('open');
            }
        });
    });
</script>

<script>
// Gestion des propositions de lettrage automatique
async function rechercherPropositions() {
    console.log('🔍 [JS] Début de la recherche de propositions');
    
    // Récupérer le client filtré
    const clientFiltre = document.getElementById('clientHiddenInput')?.value || '';
    console.log('🔍 [JS] Client filtré:', clientFiltre || 'tous');
    
    const container = document.getElementById('propositionsContainer');
    const loading = document.getElementById('propositionsLoading');
    const list = document.getElementById('propositionsList');
    const empty = document.getElementById('propositionsEmpty');
    const btn = document.getElementById('btnRechercherPropositions');
    
    // Afficher le conteneur et le loading
    console.log('🔍 [JS] Affichage de l\'interface de chargement');
    container.style.display = 'block';
    loading.style.display = 'block';
    list.style.display = 'none';
    empty.style.display = 'none';
    btn.disabled = true;
    btn.innerHTML = '<i class="bi bi-arrow-repeat spin"></i> Recherche...';
    
    try {
        console.log('🔍 [JS] Envoi de la requête au serveur...');
        let url = '@Url.Action("ProposerLettrages", "Grandlivre")';
        if (clientFiltre) {
            url += '?client=' + encodeURIComponent(clientFiltre);
        }
        console.log('🔍 [JS] URL:', url);
        
        const startTime = Date.now();
        const response = await fetch(url);
        const elapsedTime = Date.now() - startTime;
        console.log(`🔍 [JS] Réponse reçue après ${elapsedTime}ms, status: ${response.status}`);
        
        if (!response.ok) {
            console.error('🔍 [JS] Erreur HTTP:', response.status, response.statusText);
            throw new Error(`HTTP error! status: ${response.status}`);
        }
        
        console.log('🔍 [JS] Parsing de la réponse JSON...');
        const result = await response.json();
        console.log('🔍 [JS] Résultat parsé:', result);
        console.log('🔍 [JS] Success:', result.success);
        console.log('🔍 [JS] Nombre de propositions:', result.propositions ? result.propositions.length : 0);
        
        loading.style.display = 'none';
        btn.disabled = false;
        btn.innerHTML = '<i class="bi bi-search"></i> Rechercher les propositions';
        
        if (result.success && result.propositions && result.propositions.length > 0) {
            console.log('🔍 [JS] Affichage des propositions dans le tableau:', result.propositions.length);
            
            // Filtrer les propositions pour exclure celles avec des écritures déjà lettrées
            const propositionsFiltrees = afficherPropositionsDansTableau(result.propositions);
            
            // Afficher uniquement les propositions filtrées
            if (propositionsFiltrees.length > 0) {
                afficherPropositions(propositionsFiltrees);
            list.style.display = 'block';
            } else {
                console.log('🔍 [JS] Toutes les propositions contiennent des écritures déjà lettrées');
                empty.style.display = 'block';
            }
        } else {
            console.log('🔍 [JS] Aucune proposition trouvée');
            empty.style.display = 'block';
        }
    } catch (error) {
        console.error('🔍 [JS] Erreur complète:', error);
        console.error('🔍 [JS] Stack:', error.stack);
        loading.style.display = 'none';
        btn.disabled = false;
        btn.innerHTML = '<i class="bi bi-search"></i> Rechercher les propositions';
        alert('Erreur lors de la recherche des propositions: ' + error.message);
    }
}

function afficherPropositionsDansTableau(propositions) {
    console.log('🔍 [JS] Affichage des propositions dans le tableau');
    
    // Récupérer les IDs des écritures déjà lettrées depuis le tableau
    const ecrituresLettre = new Set();
    document.querySelectorAll('tr[data-ecriture-id]').forEach(row => {
        const lettrageCell = row.querySelector('.lettrage-cell');
        if (lettrageCell) {
            const lettrageBadge = lettrageCell.querySelector('.lettrage-badge');
            if (lettrageBadge) {
                const ecritureId = parseInt(row.getAttribute('data-ecriture-id'), 10);
                if (!isNaN(ecritureId)) {
                    ecrituresLettre.add(ecritureId);
                }
            }
        }
    });
    
    console.log(`🔍 [JS] ${ecrituresLettre.size} écritures déjà lettrées détectées dans le tableau`);
    
    // Filtrer les propositions pour exclure celles avec des écritures déjà lettrées
    const propositionsValides = propositions.filter(prop => {
        const contientEcritureLettre = prop.ecritureIds.some(id => ecrituresLettre.has(id));
        if (contientEcritureLettre) {
            console.log(`🔍 [JS] Proposition pour ${prop.nomClient} exclue (contient écriture déjà lettrée)`);
        }
        return !contientEcritureLettre;
    });
    
    console.log(`🔍 [JS] ${propositionsValides.length} propositions valides après filtrage (sur ${propositions.length} totales)`);
    
    // Réinitialiser toutes les sélections précédentes
    document.querySelectorAll('.ecriture-checkbox').forEach(cb => {
        cb.checked = false;
        cb.closest('tr')?.classList.remove('proposition-highlight');
    });
    
    // Pour chaque proposition valide, cocher les écritures correspondantes
    propositionsValides.forEach((prop, propIndex) => {
        prop.ecritureIds.forEach(ecritureId => {
            const checkbox = document.querySelector(`.ecriture-checkbox[value="${ecritureId}"]`);
            if (checkbox) {
                checkbox.checked = true;
                const row = checkbox.closest('tr');
                if (row) {
                    row.classList.add('proposition-highlight');
                }
            }
        });
    });
    
    // Mettre à jour la sélection
    updateSelection();
    
    // Faire défiler jusqu'à la première proposition
    const firstHighlighted = document.querySelector('.proposition-highlight');
    if (firstHighlighted) {
        firstHighlighted.scrollIntoView({ behavior: 'smooth', block: 'center' });
    }
    
    console.log('🔍 [JS] Propositions affichées dans le tableau');
    
    // Retourner les propositions filtrées pour l'affichage
    return propositionsValides;
}

